modules = ["nodejs-20", "web", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["ffmpeg", "xorg.xorgserver", "chromium"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Server"

[[workflows.workflow]]
name = "Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 33185
externalPort = 6800

[[ports]]
localPort = 34989
externalPort = 3000

[[ports]]
localPort = 35881
externalPort = 5173

[[ports]]
localPort = 36551
externalPort = 5000

[[ports]]
localPort = 36627
externalPort = 8008

[[ports]]
localPort = 36881
externalPort = 3002

[[ports]]
localPort = 37001
externalPort = 4200

[[ports]]
localPort = 37241
externalPort = 3001

[[ports]]
localPort = 40011
externalPort = 3003

[[ports]]
localPort = 43259
externalPort = 6000

[[ports]]
localPort = 55200
externalPort = 8000

[deployment]
deploymentTarget = "autoscale"
run = ["npm", "run", "start"]
build = ["npm", "run", "build"]
