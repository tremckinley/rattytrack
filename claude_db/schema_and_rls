CREATE OR REPLACE FUNCTION auth.user_role()
RETURNS TEXT AS $
BEGIN
    RETURN (
        SELECT role
        FROM users
        WHERE supabase_user_id = auth.uid()
    );
END;
$ LANGUAGE plpgsql SECURITY DEFINER;

-- ============================================================================
-- FUNCTION TO LOG USER ACTIONS
-- ============================================================================

CREATE OR REPLACE FUNCTION log_user_action()
RETURNS TRIGGER AS $
DECLARE
    current_user_id UUID;
    current_user_email TEXT;
BEGIN
    -- Get current user info
    SELECT id, email INTO current_user_id, current_user_email
    FROM users
    WHERE supabase_user_id = auth.uid();
    
    -- Only log if user is authenticated
    IF current_user_id IS NOT NULL THEN
        INSERT INTO audit_log (
            user_id,
            user_email,
            action_type,
            table_name,
            record_id,
            old_values,
            new_values
        ) VALUES (
            current_user_id,
            current_user_email,
            TG_OP,
            TG_TABLE_NAME,
            COALESCE(NEW.id, OLD.id),
            CASE WHEN TG_OP = 'DELETE' THEN row_to_json(OLD) ELSE NULL END,
            CASE WHEN TG_OP IN ('INSERT', 'UPDATE') THEN row_to_json(NEW) ELSE NULL END
        );
    END IF;
    
    RETURN COALESCE(NEW, OLD);
END;
$ LANGUAGE plpgsql SECURITY DEFINER;

-- Apply audit logging to critical tables
CREATE TRIGGER audit_transcription_segments
    AFTER INSERT OR UPDATE OR DELETE ON transcription_segments
    FOR EACH ROW EXECUTE FUNCTION log_user_action();

CREATE TRIGGER audit_segment_issues
    AFTER INSERT OR UPDATE OR DELETE ON segment_issues
    FOR EACH ROW EXECUTE FUNCTION log_user_action();

CREATE TRIGGER audit_issues
    AFTER INSERT OR UPDATE OR DELETE ON issues
    FOR EACH ROW EXECUTE FUNCTION log_user_action();

CREATE TRIGGER audit_legislators
    AFTER INSERT OR UPDATE OR DELETE ON legislators
    FOR EACH ROW EXECUTE FUNCTION log_user_action();