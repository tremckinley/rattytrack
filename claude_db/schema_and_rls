-- ============================================================================
-- VIEWS FOR COMMON QUERIES
-- ============================================================================

CREATE VIEW meeting_summaries AS
SELECT 
    m.id,
    m.title,
    m.scheduled_start,
    m.actual_start,
    m.meeting_type,
    lb.name as legislative_body_name,
    j.name as jurisdiction_name,
    COUNT(DISTINCT ts.id) as segment_count,
    COUNT(DISTINCT ts.speaker_id) as unique_speakers,
    SUM(ts.end_time_seconds - ts.start_time_seconds) as total_speaking_time_seconds,
    COUNT(DISTINCT si.issue_id) as unique_issues_discussed,
    m.processing_status,
    m.transcription_status
FROM meetings m
LEFT JOIN legislative_bodies lb ON m.legislative_body_id = lb.id
LEFT JOIN jurisdictions j ON lb.jurisdiction_id = j.id
LEFT JOIN transcription_segments ts ON m.id = ts.meeting_id
LEFT JOIN segment_issues si ON ts.id = si.segment_id
GROUP BY m.id, lb.name, j.name;

CREATE VIEW legislator_profiles AS
SELECT 
    l.id,
    l.full_name,
    l.title,
    l.district,
    l.party_affiliation,
    lb.name as legislative_body_name,
    j.name as jurisdiction_name,
    COUNT(DISTINCT ts.id) as total_segments,
    SUM(ts.end_time_seconds - ts.start_time_seconds) as total_speaking_time_seconds,
    COUNT(DISTINCT b.id) as bills_sponsored,
    COUNT(DISTINCT ma.meeting_id) as meetings_attended,
    l.is_active
FROM legislators l
LEFT JOIN legislative_bodies lb ON l.legislative_body_id = lb.id
LEFT JOIN jurisdictions j ON lb.jurisdiction_id = j.id
LEFT JOIN transcription_segments ts ON l.id = ts.speaker_id
LEFT JOIN bills b ON l.id = b.primary_sponsor_id
LEFT JOIN meeting_attendees ma ON l.id = ma.legislator_id AND ma.attendance_status = 'present'
GROUP BY l.id, lb.name, j.name;

