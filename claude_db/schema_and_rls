-- ============================================================================
-- CAPYTRACK AI - POSTGRESQL DATABASE SCHEMA
-- Legislative Meeting Analysis Platform
-- ============================================================================

-- ============================================================================
-- JURISDICTION & ORGANIZATION
-- ============================================================================

CREATE TABLE jurisdictions (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name VARCHAR(255) NOT NULL,
    jurisdiction_type VARCHAR(50) NOT NULL, -- 'city', 'county', 'state', 'federal'
    state VARCHAR(2),
    city VARCHAR(100),
    timezone VARCHAR(50) NOT NULL DEFAULT 'America/Chicago',
    is_active BOOLEAN DEFAULT true,
    metadata JSONB, -- additional jurisdiction-specific data
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

CREATE TABLE legislative_bodies (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    jurisdiction_id UUID REFERENCES jurisdictions(id) ON DELETE CASCADE,
    name VARCHAR(255) NOT NULL, -- 'City Council', 'Planning Commission', etc.
    description TEXT,
    body_type VARCHAR(50), -- 'council', 'commission', 'board', 'committee'
    website_url VARCHAR(500),
    video_source_url VARCHAR(500), -- YouTube channel, streaming platform
    meeting_schedule JSONB, -- recurring meeting patterns
    is_active BOOLEAN DEFAULT true,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- ============================================================================
-- LEGISLATORS & PEOPLE
-- ============================================================================

CREATE TABLE legislators (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    legislative_body_id UUID REFERENCES legislative_bodies(id) ON DELETE SET NULL,
    first_name VARCHAR(100) NOT NULL,
    last_name VARCHAR(100) NOT NULL,
    full_name VARCHAR(255) NOT NULL,
    title VARCHAR(100), -- 'Council Member', 'Mayor', 'Commissioner'
    district VARCHAR(50),
    party_affiliation VARCHAR(50),
    email VARCHAR(255),
    phone VARCHAR(20),
    office_address TEXT,
    photo_url VARCHAR(500),
    website_url VARCHAR(500),
    social_media JSONB, -- {twitter, facebook, instagram, etc}
    
    -- Demographics
    date_of_birth DATE,
    gender VARCHAR(50),
    race_ethnicity VARCHAR(100),
    education TEXT,
    occupation TEXT,
    
    -- Term information
    term_start DATE,
    term_end DATE,
    is_active BOOLEAN DEFAULT true,
    
    -- AI Recognition Data
    voice_profile_id VARCHAR(255), -- reference to voice recognition model
    face_profile_id VARCHAR(255), -- reference to face recognition model
    
    bio TEXT,
    metadata JSONB,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

CREATE INDEX idx_legislators_body ON legislators(legislative_body_id);
CREATE INDEX idx_legislators_active ON legislators(is_active);
CREATE INDEX idx_legislators_name ON legislators(last_name, first_name);

-- ============================================================================
-- MEETINGS
-- ============================================================================

CREATE TABLE meetings (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    legislative_body_id UUID REFERENCES legislative_bodies(id) ON DELETE CASCADE,
    
    meeting_type VARCHAR(50) NOT NULL, -- 'regular', 'special', 'committee', 'public_hearing'
    title VARCHAR(500) NOT NULL,
    description TEXT,
    
    -- Scheduling
    scheduled_start TIMESTAMP WITH TIME ZONE,
    scheduled_end TIMESTAMP WITH TIME ZONE,
    actual_start TIMESTAMP WITH TIME ZONE,
    actual_end TIMESTAMP WITH TIME ZONE,
    
    -- Video/Streaming
    video_url VARCHAR(500), -- YouTube or streaming URL
    video_platform VARCHAR(50), -- 'youtube', 'vimeo', 'custom'
    video_id VARCHAR(255), -- platform-specific video ID
    video_duration_seconds INTEGER,
    
    -- Processing Status
    processing_status VARCHAR(50) DEFAULT 'pending', -- 'pending', 'processing', 'completed', 'failed'
    transcription_status VARCHAR(50) DEFAULT 'pending',
    analysis_status VARCHAR(50) DEFAULT 'pending',
    
    -- Location
    location VARCHAR(255),
    is_virtual BOOLEAN DEFAULT false,
    
    -- Metadata
    agenda_url VARCHAR(500),
    minutes_url VARCHAR(500),
    attendance_count INTEGER,
    
    metadata JSONB,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

CREATE INDEX idx_meetings_body ON meetings(legislative_body_id);
CREATE INDEX idx_meetings_date ON meetings(scheduled_start);
CREATE INDEX idx_meetings_status ON meetings(processing_status);

CREATE TABLE meeting_attendees (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    meeting_id UUID REFERENCES meetings(id) ON DELETE CASCADE,
    legislator_id UUID REFERENCES legislators(id) ON DELETE CASCADE,
    attendance_status VARCHAR(50) NOT NULL, -- 'present', 'absent', 'excused', 'late', 'left_early'
    arrival_time TIMESTAMP WITH TIME ZONE,
    departure_time TIMESTAMP WITH TIME ZONE,
    notes TEXT,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

CREATE INDEX idx_attendees_meeting ON meeting_attendees(meeting_id);
CREATE INDEX idx_attendees_legislator ON meeting_attendees(legislator_id);

-- ============================================================================
-- TRANSCRIPTION
-- ============================================================================

CREATE TABLE transcription_segments (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    meeting_id UUID REFERENCES meetings(id) ON DELETE CASCADE,
    
    -- Timing
    start_time_seconds DECIMAL(10, 3) NOT NULL,
    end_time_seconds DECIMAL(10, 3) NOT NULL,
    
    -- Speaker Attribution
    speaker_id UUID REFERENCES legislators(id) ON DELETE SET NULL,
    speaker_name VARCHAR(255), -- fallback if not matched to legislator
    speaker_title VARCHAR(100),
    
    -- Transcription
    text TEXT NOT NULL,
    text_normalized TEXT, -- cleaned version for search/analysis
    
    -- AI Confidence & Processing
    transcription_confidence DECIMAL(5, 4), -- 0.0000 to 1.0000
    speaker_identification_confidence DECIMAL(5, 4),
    speaker_identification_method VARCHAR(50), -- 'voice', 'video', 'manual', 'pattern'
    ai_model_version VARCHAR(50), -- 'whisper-v3', 'gpt-4', etc.
    
    -- Manual Override
    is_manually_verified BOOLEAN DEFAULT false,
    manually_corrected_by UUID, -- references users table
    correction_timestamp TIMESTAMP WITH TIME ZONE,
    
    -- Search & Analysis
    language VARCHAR(10) DEFAULT 'en',
    word_count INTEGER,
    sentiment_score DECIMAL(5, 4), -- -1 to 1
    
    metadata JSONB,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

CREATE INDEX idx_segments_meeting ON transcription_segments(meeting_id);
CREATE INDEX idx_segments_speaker ON transcription_segments(speaker_id);
CREATE INDEX idx_segments_time ON transcription_segments(meeting_id, start_time_seconds);
CREATE INDEX idx_segments_text_search ON transcription_segments USING gin(to_tsvector('english', text));

-- ============================================================================
-- ISSUES & TOPICS
-- ============================================================================

CREATE TABLE issues (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    jurisdiction_id UUID REFERENCES jurisdictions(id) ON DELETE CASCADE,
    
    name VARCHAR(255) NOT NULL,
    slug VARCHAR(255) NOT NULL, -- URL-friendly version
    description TEXT,
    
    -- Taxonomy
    parent_issue_id UUID REFERENCES issues(id) ON DELETE SET NULL, -- for hierarchical categories
    category_level INTEGER DEFAULT 1, -- 1 = top level, 2 = subcategory, etc.
    
    -- AI Generation vs Manual
    is_ai_generated BOOLEAN DEFAULT true,
    ai_confidence DECIMAL(5, 4),
    first_detected_at TIMESTAMP WITH TIME ZONE,
    
    -- Manual Curation
    is_approved BOOLEAN DEFAULT false,
    approved_by UUID, -- references users table
    approved_at TIMESTAMP WITH TIME ZONE,
    
    -- Usage Stats (denormalized for performance)
    mention_count INTEGER DEFAULT 0,
    segment_count INTEGER DEFAULT 0,
    legislator_count INTEGER DEFAULT 0,
    
    -- Metadata
    color_hex VARCHAR(7), -- for UI visualization
    icon_name VARCHAR(50),
    keywords TEXT[], -- array of related keywords
    
    is_active BOOLEAN DEFAULT true,
    metadata JSONB,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    
    UNIQUE(jurisdiction_id, slug)
);

CREATE INDEX idx_issues_jurisdiction ON issues(jurisdiction_id);
CREATE INDEX idx_issues_parent ON issues(parent_issue_id);
CREATE INDEX idx_issues_active ON issues(is_active);
CREATE INDEX idx_issues_name ON issues(name);

CREATE TABLE segment_issues (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    segment_id UUID REFERENCES transcription_segments(id) ON DELETE CASCADE,
    issue_id UUID REFERENCES issues(id) ON DELETE CASCADE,
    
    -- AI Analysis
    relevance_score DECIMAL(5, 4) NOT NULL, -- 0.0000 to 1.0000
    sentiment_score DECIMAL(5, 4), -- -1 to 1 (negative to positive)
    ai_model_version VARCHAR(50),
    
    -- Manual Override
    is_manually_verified BOOLEAN DEFAULT false,
    manually_added BOOLEAN DEFAULT false,
    verified_by UUID,
    verification_timestamp TIMESTAMP WITH TIME ZONE,
    
    -- Context
    key_phrases TEXT[], -- important phrases that triggered this classification
    
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    
    UNIQUE(segment_id, issue_id)
);

CREATE INDEX idx_segment_issues_segment ON segment_issues(segment_id);
CREATE INDEX idx_segment_issues_issue ON segment_issues(issue_id);
CREATE INDEX idx_segment_issues_relevance ON segment_issues(relevance_score DESC);

